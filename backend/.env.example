# Copy to .env (gitignored) for `docker compose up`.

# Pre-baked UUID treated as the signed-in user for any X-Coders-User-less
# request — only used in local dev (the platform gate stamps the header
# in prod). Generate your own with `python -c "import uuid; print(uuid.uuid4())"`.
DEV_FAKE_USER=00000000-0000-0000-0000-000000000001

# Backend listens on 0.0.0.0:8000; compose maps that to localhost:8000.
DATABASE_URL=postgresql+asyncpg://app:app@db:5432/app

# Managed LLM (coders.kr `type: llm`). In production coders.yaml injects
# these from the `ai` component. Leave them unset locally and the briefing
# summariser falls back to a deterministic composer (no AI editing, but the
# crawled headlines + indicators still render). To exercise the AI path
# locally, point these at any Anthropic-compatible endpoint:
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-sonnet-4-6
